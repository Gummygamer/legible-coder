-- legible-coder: an interactive CLI coding assistant for the Legible language
-- Powered by openai/gpt-oss-120b via the Groq API
-- Model can be overridden with the LEGIBLE_CODER_MODEL environment variable

-- ─── Tool schema helpers ──────────────────────────────────────────────────────

function make_param(pname: text, pdesc: text): a mapping from text to text
  intent: wrap pname and pdesc into a type and description mapping
  {"type": "string", "description": pdesc}
end

function make_tool(name: text, description: text, param_names: a list of text, param_descs: a list of text, required_params: a list of text): a mapping from text to text
  intent: put name, description, properties, and required into a function schema mapping
  mutable properties: a mapping from text to text = {}
  mutable i: integer = 0
  for pname in param_names do
    let pdesc: text = get(param_descs, i)
    set properties = put(properties, pname, make_param(pname, pdesc))
    set i = i + 1
  end
  {
    "type": "function",
    "function": {
      "name": name,
      "description": description,
      "parameters": {
        "type": "object",
        "properties": properties,
        "required": required_params
      }
    }
  }
end

function file_tools(): a list of a mapping from text to text
  intent: build read_file, write_file, list_dir, and read_dir_recursive tool schemas
  let read_tool: a mapping from text to text = make_tool("read_file", "Read the contents of a file at the given path.", ["path"], ["The file path to read"], ["path"])
  let write_tool: a mapping from text to text = make_tool("write_file", "Write content to a file at the given path. Creates or overwrites.", ["path", "content"], ["The file path to write", "The content to write"], ["path", "content"])
  let list_tool: a mapping from text to text = make_tool("list_dir", "List files and directories at a given path (one level only).", ["path"], ["The directory path to list"], ["path"])
  let recursive_tool: a mapping from text to text = make_tool("read_dir_recursive", "Recursively list all files under a directory. Use this instead of repeated list_dir calls to understand the project structure.", ["path"], ["The root directory to list recursively"], ["path"])
  [read_tool, write_tool, list_tool, recursive_tool]
end

function search_tools(): a list of a mapping from text to text
  intent: build shell_exec and grep tool schemas
  let shell_tool: a mapping from text to text = make_tool("shell_exec", "Run a shell command and return stdout, stderr, and exit code.", ["command"], ["The shell command to execute"], ["command"])
  let grep_tool: a mapping from text to text = make_tool("grep", "Search for a pattern in files. Returns matching lines.", ["pattern", "path", "glob"], ["The regex pattern to search for", "Directory or file to search in", "Glob to filter files, e.g. *.lbl"], ["pattern"])
  [shell_tool, grep_tool]
end

function tool_definitions(): a list of a mapping from text to text
  intent: combine file_tools and search_tools into one list
  let ft: a list of a mapping from text to text = file_tools()
  let st: a list of a mapping from text to text = search_tools()
  reduce(st, ft, fn(acc: a list of a mapping from text to text, t: a mapping from text to text): a list of a mapping from text to text => append(acc, t))
end

-- ─── Tool validation ──────────────────────────────────────────────────────────

-- Strip model special-token suffixes like "<|channel|>commentary" from a tool name
function clean_tool_name(name: text): text
  intent: strip everything from the first angle bracket onward in name
  let bracket: integer = unwrap_or(index_of(name, "<"), -1)
  if bracket > 0 then
    trim(substring(name, 0, bracket))
  else
    name
  end
end

function is_known_tool(name: text): boolean
  intent: compare the cleaned name to read_file, write_file, shell_exec, list_dir, read_dir_recursive, and grep
  let n: text = clean_tool_name(name)
  n == "read_file" or n == "write_file" or n == "shell_exec" or
  n == "list_dir" or n == "read_dir_recursive" or n == "grep"
end

function describe_tool_call(name: text, arguments: text): text
  intent: format name with its path, command, or pattern argument as a short label
  let args: a mapping from text to text = json_parse(arguments)
  if name == "read_file" or name == "list_dir" or name == "read_dir_recursive" then
    name ++ "  " ++ unwrap_or(get(args, "path"), "")
  else if name == "write_file" then
    name ++ "  " ++ unwrap_or(get(args, "path"), "")
  else if name == "shell_exec" then
    let cmd: text = unwrap_or(get(args, "command"), "")
    let preview: text = if text_length(cmd) > 60 then substring(cmd, 0, 60) ++ "…" else cmd end
    name ++ "  $ " ++ preview
  else if name == "grep" then
    let pat: text = unwrap_or(get(args, "pattern"), "")
    let path: text = unwrap_or(get(args, "path"), ".")
    name ++ "  /" ++ pat ++ "/  " ++ path
  else
    name
  end
end

-- ─── Tool execution ───────────────────────────────────────────────────────────

function exec_write_file(args: a mapping from text to text): text
  intent: write content to path and print a diff if the file already existed
  let path: text = get(args, "path")
  let content: text = get(args, "content")
  if file_exists(path) then
    let old_content: text = read_file(path)
    write_file("/tmp/legible_coder_old", old_content)
    write_file(path, content)
    let diff_output: text = get(shell_exec("diff -u /tmp/legible_coder_old " ++ path ++ " 2>&1 | head -120"), "stdout")
    if text_length(diff_output) > 0 then
      print("")
      print(diff_output)
    end
  else
    write_file(path, content)
  end
  "File written successfully: " ++ path
end

function exec_shell(args: a mapping from text to text): text
  intent: run the command and return exit_code, stdout, and stderr as text
  let result: a mapping from text to text = shell_exec(get(args, "command"))
  let base: text = "exit_code: " ++ to_text(get(result, "exit_code"))
  let with_out: text = if text_length(get(result, "stdout")) > 0 then base ++ "\nstdout:\n" ++ get(result, "stdout") else base end
  if text_length(get(result, "stderr")) > 0 then with_out ++ "\nstderr:\n" ++ get(result, "stderr") else with_out end
end

function exec_grep(args: a mapping from text to text): text
  intent: run grep with pattern, path, and optional glob and return matching lines
  let pattern: text = get(args, "pattern")
  let path: text = unwrap_or(get(args, "path"), ".")
  let glob_pattern: text = unwrap_or(get(args, "glob"), "")
  let cmd: text = if text_length(glob_pattern) > 0 then
    "grep -rn --include='" ++ glob_pattern ++ "' '" ++ pattern ++ "' " ++ path ++ " 2>&1 | head -50"
  else
    "grep -rn '" ++ pattern ++ "' " ++ path ++ " 2>&1 | head -50"
  end
  let stdout: text = get(shell_exec(cmd), "stdout")
  if text_length(stdout) > 0 then stdout else "No matches found." end
end

function execute_tool(name: text, arguments: text): text
  intent: parse arguments and dispatch to read_file, write_file, shell_exec, list_dir, read_dir_recursive, or grep
  let args: a mapping from text to text = json_parse(arguments)
  if name == "read_file" then
    let path: text = get(args, "path")
    if file_exists(path) then read_file(path) else "Error: file not found: " ++ path end
  else if name == "write_file" then
    exec_write_file(args)
  else if name == "shell_exec" then
    exec_shell(args)
  else if name == "list_dir" then
    let path: text = get(args, "path")
    if is_dir(path) then join(list_dir(path), "\n") else "Error: not a directory: " ++ path end
  else if name == "read_dir_recursive" then
    get(shell_exec("find " ++ get(args, "path") ++ " -type f | sort 2>&1 | head -200"), "stdout")
  else if name == "grep" then
    exec_grep(args)
  else
    "Error: unknown tool: " ++ name
  end
end

-- ─── System prompt ────────────────────────────────────────────────────────────

function prompt_syntax_ref(): text
  intent: return the Legible syntax reference section covering bindings, types, functions, records, unions, control flow, and operators
  "════ LEGIBLE LANGUAGE REFERENCE ════\n\n" ++
  "BINDINGS:\n" ++
  "  let name: type = value          -- immutable\n" ++
  "  mutable name: type = value      -- mutable\n" ++
  "  set name = new_value            -- update a mutable binding\n\n" ++
  "TYPES:\n" ++
  "  integer  decimal  text  boolean  nothing\n" ++
  "  a list of T\n" ++
  "  a mapping from K to V\n" ++
  "  an optional T\n\n" ++
  "FUNCTIONS:\n" ++
  "  function name(param: type, param2: type): return_type\n" ++
  "    intent: what this function does\n" ++
  "    body\n" ++
  "  end\n\n" ++
  "RECORDS:\n" ++
  "  record Name\n" ++
  "    field: type\n" ++
  "  end\n" ++
  "  let x: Name = Name \{ field: value \}\n" ++
  "  let updated: Name = x with \{ field: new_value \}\n\n" ++
  "UNIONS:\n" ++
  "  union Shape\n" ++
  "    Circle \{ radius: decimal \}\n" ++
  "    Point\n" ++
  "  end\n" ++
  "  match s when Circle \{ radius \} then radius * 3.14 when Point then 0.0 end\n\n" ++
  "CONTROL FLOW:\n" ++
  "  if cond then ... else if cond then ... else ... end\n" ++
  "  for item in list do ... end\n" ++
  "  while cond do ... end\n\n" ++
  "OPERATORS:\n" ++
  "  ++ (text concat)   |> (pipeline)   and or not\n\n" ++
  "LAMBDAS:\n" ++
  "  fn(x: integer): boolean => x > 0\n\n" ++
  "MODULES:\n" ++
  "  use module_name           -- loads module_name.lbl\n" ++
  "  public function foo ...   -- export from a module\n" ++
  "  module_name.foo()         -- call an exported function\n\n"
end

function prompt_builtins_and_example(): text
  intent: return the built-ins list and a complete working Legible example
  "BUILT-INS:\n" ++
  "  print(v)  read_line()  to_text(v)  to_integer(v)  to_decimal(v)\n" ++
  "  length(list)  append(list, item)  filter(list, fn)  map(list, fn)  reduce(list, init, fn)\n" ++
  "  sort_by(list, fn)  find(list, fn)  take(list, n)  drop(list, n)  range(a, b)\n" ++
  "  split(text, delim)  join(list, sep)  trim(s)  replace(s, from, to)\n" ++
  "  substring(s, start, len)  text_length(s)  contains_text(s, sub)  index_of(s, sub)\n" ++
  "  uppercase(s)  lowercase(s)  starts_with(s, p)  ends_with(s, p)\n" ++
  "  keys(map)  values(map)  get(map, key)  put(map, key, val)  has_key(map, key)\n" ++
  "  unwrap(opt)  unwrap_or(opt, default)  is_some(opt)  is_none(opt)\n" ++
  "  abs(n)  max(a,b)  min(a,b)  floor(n)  ceil(n)  round(n)\n" ++
  "  random_int(max)  random_decimal()  skip()\n" ++
  "  read_file(path)  write_file(path, content)  file_exists(path)\n" ++
  "  shell_exec(cmd)  env_get(name)  get_cwd()  list_dir(path)  is_dir(path)\n" ++
  "  json_parse(text)  json_encode(value)  json_valid(text)\n" ++
  "  http_client_get(url, headers)  http_client_post(url, headers, body)\n\n" ++
  "COMPLETE EXAMPLE:\n" ++
  "  record Creature\n" ++
  "    name: text\n" ++
  "    hp: integer\n" ++
  "    level: integer\n" ++
  "  end\n\n" ++
  "  function describe(c: Creature): text\n" ++
  "    intent: format creature name, level, and hp as a status line\n" ++
  "    c.name ++ \" lv\" ++ to_text(c.level) ++ \" HP:\" ++ to_text(c.hp)\n" ++
  "  end\n\n" ++
  "  function level_up(c: Creature): Creature\n" ++
  "    intent: return c with level incremented and hp raised by ten\n" ++
  "    c with \{ level: c.level + 1, hp: c.hp + 10 \}\n" ++
  "  end\n\n" ++
  "  function main(): nothing\n" ++
  "    intent: create a creature, level it up, and print both states\n" ++
  "    let p: Creature = Creature \{ name: \"Flareon\", hp: 40, level: 1 \}\n" ++
  "    print(describe(p))\n" ++
  "    let p2: Creature = level_up(p)\n" ++
  "    print(describe(p2))\n" ++
  "  end\n\n" ++
  "Run programs with: legible run file.lbl\n\n"
end

function prompt_rules(): text
  intent: return the rules section listing common Legible mistakes to avoid
  "RULES:\n" ++
  "- Every function parameter needs a colon: fn(x: text) not fn(x text)\n" ++
  "- Every let/mutable binding needs a colon: let x: text = ... not let x text = ...\n" ++
  "- No semicolons, no curly braces for blocks — use end\n" ++
  "- Strings must be on one line; use ++ to concatenate across lines\n" ++
  "- In Legible source code, ALL arguments are positional — shell_exec(cmd) not shell_exec(command = cmd)\n" ++
  "- 'any' is NOT a valid type; use 'text' for unknown value types\n" ++
  "- shell_exec returns 'a mapping from text to text'; all values including exit_code are text\n" ++
  "- Use random_int(max) for random integers; do NOT use python or shell for RNG\n" ++
  "- No 'return' keyword; the last expression in a function body is returned\n" ++
  "- intent: values are unquoted plain text: intent: do something — NOT intent: \"do something\"\n" ++
  "- Dot access only works on records (record.field); for mappings use get(map, \"key\")\n" ++
  "- Types require the article: 'a list of T' and 'a mapping from K to V' — never 'list of T' or 'mapping from K to V'\n" ++
  "- No 'elseif' keyword — use 'else if' (two words)\n" ++
  "- No 'break' keyword — use a mutable boolean flag to exit loops\n" ++
  "- No array/list indexing with [] — use get(list, index) instead\n" ++
  "- Semicolons are not allowed anywhere, including inside intent descriptions\n" ++
  "- Comments use -- not #: write -- this is a comment, never # this is a comment\n" ++
  "- if-branches cannot be empty; use skip() as a no-op: if cond then skip() end\n" ++
  "- Avoid Unicode characters in code: use ASCII dash - not em-dash, straight quotes not curly quotes\n" ++
  "- Write code to files with write_file, then run with shell_exec\n" ++
  "- Keep responses concise; use tools to act rather than describing what you would do"
end

function system_prompt(): text
  intent: compose the header, syntax reference, builtins, example, and rules into the full system prompt
  let cwd: text = get_cwd()
  "You are legible-coder, an interactive CLI coding assistant. " ++
  "You write code in the Legible programming language and perform tasks by running Legible scripts.\n\n" ++
  "Current working directory: " ++ cwd ++ "\n\n" ++
  "TOOLS: read_file, write_file, shell_exec, list_dir, read_dir_recursive, grep.\n" ++
  "Use read_dir_recursive to understand project structure in ONE call instead of many list_dir calls.\n\n" ++
  prompt_syntax_ref() ++
  prompt_builtins_and_example() ++
  prompt_rules()
end

-- ─── API ──────────────────────────────────────────────────────────────────────

function build_request(model: text, messages: a list of a mapping from text to text): a mapping from text to text
  intent: put model, messages, tools, and max_tokens into the chat completions request mapping
  {
    "model": model,
    "messages": messages,
    "tools": tool_definitions(),
    "tool_choice": "auto",
    "max_tokens": 16384
  }
end

function call_groq(api_key: text, request_body: a mapping from text to text): a mapping from text to text
  intent: encode request_body as json and post it to the chat completions endpoint with auth headers
  let headers: a mapping from text to text = {
    "Authorization": "Bearer " ++ api_key,
    "Content-Type": "application/json"
  }
  let body_json: text = json_encode(request_body)
  http_client_post(
    "https://api.groq.com/openai/v1/chat/completions",
    headers,
    body_json
  )
end

-- ─── UI helpers ───────────────────────────────────────────────────────────────

function print_banner(model: text): nothing
  intent: print the legible-coder name, model, and cwd as the startup header
  print("")
  print("  legible-coder")
  print("  Interactive Legible coding assistant")
  print("  Model: " ++ model ++ " via Groq")
  print("  ────────────────────────────────────────────")
  let cwd: text = get_cwd()
  print("  cwd: " ++ cwd)
  print("  Type your request, or 'quit' to exit.")
  print("")
end

function print_separator(): nothing
  intent: emit a divider
  print("  ────────────────────────────────────────────")
end

-- ─── Tool call batch execution ────────────────────────────────────────────────

record BatchResult
  messages: a list of a mapping from text to text
  count: integer
  stop: boolean
end

function run_tool_batch(messages: a list of a mapping from text to text, valid_calls: a list of a mapping from text to text, tool_count: integer): BatchResult
  intent: append the assistant tool_calls message, execute each call, and return updated messages and count
  let asst_msg: a mapping from text to text = {"role": "assistant", "content": none, "tool_calls": valid_calls}
  mutable msgs: a list of a mapping from text to text = append(messages, asst_msg)
  mutable n: integer = tool_count
  for tc in valid_calls do
    let fn_info: a mapping from text to text = get(tc, "function")
    let tc_id: text = unwrap_or(get(tc, "id"), "")
    let fn_name: text = clean_tool_name(get(fn_info, "name"))
    let fn_args: text = get(fn_info, "arguments")
    set n = n + 1
    print("  [" ++ to_text(n) ++ "] " ++ describe_tool_call(fn_name, fn_args))
    let raw: text = execute_tool(fn_name, fn_args)
    let result: text = if text_length(raw) > 8000 then substring(raw, 0, 8000) ++ "\n... (truncated)" else raw end
    set msgs = append(msgs, {"role": "tool", "tool_call_id": tc_id, "content": result})
  end
  let hit_cap: boolean = n >= 30
  if hit_cap then print("  [warn] reached 30 tool calls this turn, stopping") end
  BatchResult {messages: msgs, count: n, stop: hit_cap}
end

-- ─── Inner API loop ───────────────────────────────────────────────────────────

function filter_valid_calls(all_calls: a list of a mapping from text to text): a list of a mapping from text to text
  intent: keep only tool calls with known names and valid JSON object arguments
  filter(all_calls, fn(tc: a mapping from text to text): boolean => is_known_tool(get(get(tc, "function"), "name")) and json_valid(get(get(tc, "function"), "arguments")) and starts_with(trim(get(get(tc, "function"), "arguments")), "\{"))
end

function handle_text_response(msg: a mapping from text to text, msgs: a list of a mapping from text to text): a list of a mapping from text to text
  intent: print content between separators and append it to msgs as an assistant message
  let content: text = unwrap_or(get(msg, "content"), "")
  if text_length(content) > 0 then
    print("")
    print_separator()
    print(content)
    print_separator()
    print("")
    append(msgs, {"role": "assistant", "content": content})
  else
    msgs
  end
end

function run_inner_loop(init_messages: a list of a mapping from text to text, messages_start: integer, key: text, model: text): a list of a mapping from text to text
  intent: call the API in a loop executing tool calls until the model returns text or an error occurs
  mutable msgs: a list of a mapping from text to text = init_messages
  mutable waiting: boolean = true
  mutable tool_count: integer = 0
  while waiting do
    let resp: a mapping from text to text = call_groq(key, build_request(model, msgs))
    let status: text = get(resp, "status")
    if status != "200" then
      let err_info: a mapping from text to text = unwrap_or(get(json_parse(get(resp, "body")), "error"), {})
      print("  API error (status " ++ status ++ "):")
      print("  " ++ unwrap_or(get(err_info, "message"), get(resp, "body")))
      set msgs = take(msgs, messages_start)
      set waiting = false
    else
      let choice: a mapping from text to text = get(get(json_parse(get(resp, "body")), "choices"), 0)
      let msg: a mapping from text to text = get(choice, "message")
      let finish: text = unwrap_or(get(choice, "finish_reason"), "stop")
      if finish == "tool_calls" then
        let valid_calls: a list of a mapping from text to text = filter_valid_calls(unwrap_or(get(msg, "tool_calls"), []))
        if length(valid_calls) > 0 then
          let batch: BatchResult = run_tool_batch(msgs, valid_calls, tool_count)
          set msgs = batch.messages
          set tool_count = batch.count
          if batch.stop then set waiting = false end
        else
          print("  [warn] all tool calls invalid, ending turn")
          set waiting = false
        end
      else
        set msgs = handle_text_response(msg, msgs)
        set waiting = false
      end
    end
  end
  msgs
end

-- ─── Main loop ────────────────────────────────────────────────────────────────

function main(): nothing
  intent: read api_key and model, print the banner, then loop reading user messages and calling the assistant
  let api_key: an optional text = env_get("GROQ_API_KEY")
  if is_none(api_key) then
    print("Error: GROQ_API_KEY environment variable is not set.")
    print("Set it with: export GROQ_API_KEY=\"your-key-here\"")
    exit_process(1)
  end
  let key: text = unwrap(api_key)
  let model: text = unwrap_or(env_get("LEGIBLE_CODER_MODEL"), "openai/gpt-oss-120b")
  print_banner(model)
  let sys_msg: a mapping from text to text = {"role": "system", "content": system_prompt()}
  mutable messages: a list of a mapping from text to text = [sys_msg]
  mutable running: boolean = true
  while running do
    print("  > ")
    let user_input: text = trim(read_line())
    if user_input == "quit" or user_input == "exit" then
      print("  Goodbye!")
      set running = false
    else if text_length(user_input) == 0 then
      print("")
    else
      set messages = append(messages, {"role": "user", "content": user_input})
      let start: integer = length(messages)
      set messages = run_inner_loop(messages, start, key, model)
    end
  end
end
